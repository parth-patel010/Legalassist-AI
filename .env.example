# ==================== LegalAssist AI Configuration ====================

# ==================== OpenAI / OpenRouter ====================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ==================== Twilio SMS Configuration ====================
# Get credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890  # Your Twilio phone number

# ==================== SendGrid Email Configuration ====================
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@legalassist.ai

# ==================== Database Configuration ====================
# For production, use a proper database URL
# Examples:
#   SQLite: sqlite:///./legalassist.db
#   PostgreSQL: postgresql://user:password@localhost/legalassist
#   MySQL: mysql://user:password@localhost/legalassist
DATABASE_URL=sqlite:///./legalassist.db

# ==================== Streamlit Secrets (for .streamlit/secrets.toml) ====================
# If using Streamlit Cloud, add these to .streamlit/secrets.toml
# Otherwise, use environment variables

# ==================== Development/Testing ====================
# Test user ID for manual testing
TEST_USER_ID=user_test_001

# ==================== Notification Preferences ====================
# Default timezone for new users (IANA timezone format)
# Examples: UTC, Asia/Kolkata, America/New_York, Europe/London
DEFAULT_TIMEZONE=UTC

# ==================== Logging ====================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
